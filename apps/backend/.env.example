# FMV AI Backend Environment Variables

# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://fmv_user:fmv_password@localhost:5432/fmv_ai?schema=public"

# Server port
PORT=3000

# JWT Secret (change in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Redis connection (for BullMQ queue)
REDIS_URL="redis://localhost:6379"

# AI Worker — Local LLM endpoint
LLM_API_URL="http://localhost:8080/v1/chat/completions"
LLM_MODEL="qwen3.6-35b-a3b"

# Email (SMTP) — for notifications
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@fmv-ai.local"

# Standalone mode: enable built-in auth
AUTH_MODE="standalone" # or "sso" for enterprise SSO/SAML/OIDC
