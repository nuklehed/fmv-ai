# ─── Infrastructure Services ────────────────────────────────────────
# PostgreSQL — production database
DATABASE_URL="postgresql://fmv_user:fmv_password@localhost:5432/fmv_ai?schema=public"

# Redis — BullMQ job queue & AI worker backend
REDIS_URL="redis://localhost:6379"

# Local LLM endpoint (Ollama-compatible API)
LLM_BASE_URL="http://localhost:11434"
LLM_MODEL="qwen2.5:32b"

# ─── Application ────────────────────────────────────────────────────
PORT=3001
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Optional (Email / SSO) ────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@fmv-ai.local"
AUTH_MODE="standalone" # or "sso" for enterprise SSO/SAML/OIDC
