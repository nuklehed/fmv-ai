generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  passwordHash         String?
  role                 String
  tenantId             String
  isActive             Boolean        @default(true)
  emailVerified        Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  approvedAssessments  Assessment[]   @relation("ApprovedAssessments")
  submittedAssessments Assessment[]   @relation("SubmittedAssessments")
  notifications        Notification[]

  @@index([tenantId, role])
  @@index([email])
}

model Hcp {
  id          String          @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?         @default("US")
  specialtyId String?
  tenantId    String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assessments Assessment[]
  specialty   Specialty?      @relation(fields: [specialtyId], references: [id])
  identifiers HcpIdentifier[]

  @@index([tenantId, isActive])
  @@index([specialtyId])
}

model HcpIdentifier {
  id        String   @id @default(uuid())
  hcpId     String
  type      String
  value     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  hcp       Hcp      @relation(fields: [hcpId], references: [id], onDelete: Cascade)

  @@unique([hcpId, type, value])
}

model Specialty {
  id            String          @id @default(uuid())
  name          String
  description   String?
  criteriaSetId String?
  isActive      Boolean         @default(true)
  tenantId      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  assessments   Assessment[]    @relation("AssessmentSpecialty")
  hcps          Hcp[]
  criteriaSet   CriteriaSet?    @relation("SpecialtyCriteriaSet", fields: [criteriaSetId], references: [id])
  rates         SpecialtyRate[]

  @@unique([name, tenantId])
  @@index([tenantId, isActive])
  @@index([criteriaSetId])
}

model CriteriaSet {
  id             String          @id @default(uuid())
  name           String
  description    String?
  systemPrompt   String?
  tierThresholds Json?
  isActive       Boolean         @default(true)
  tenantId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assessments    Assessment[]    @relation("CriteriaSetAssessments")
  questions      Question[]
  specialties    Specialty[]     @relation("SpecialtyCriteriaSet")
  rates          SpecialtyRate[]

  @@index([tenantId, isActive])
}

model Question {
  id            String      @id @default(uuid())
  criteriaSetId String
  text          String
  order         Int
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  answers       Answer[]
  criteriaSet   CriteriaSet @relation(fields: [criteriaSetId], references: [id], onDelete: Cascade)

  @@index([criteriaSetId])
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  text       String
  score      Int
  order      Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Assessment {
  id                        String       @id @default(uuid())
  hcpId                     String
  submittedByUserId         String
  specialtyId               String?
  criteriaSetId             String?
  cvText                    String?
  status                    String       @default("DRAFT")
  aiResults                 String?
  totalScore                Int?
  tierLabel                 String?
  rate                      Decimal?   @db.Decimal(10,2)
  approvedByUserId          String?
  rejectionReason           String?
  tenantId                  String
  effectiveDate             DateTime?
  renewalDate               DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  submittedAt               DateTime?
  completedAt               DateTime?
  llmRawResponse            String?
  llmUserPrompt             String?
  isActive                  Boolean      @default(false)
  supersededAt              DateTime?
  supersededByAssessmentId  String?
  previousAssessmentId      String?
  criteriaSnapshot          Json? // Frozen snapshot of { questions: [...], answers: {...}, scores } at evaluation time
  approvedByUser            User?        @relation("ApprovedAssessments", fields: [approvedByUserId], references: [id])
  supersededBy              Assessment?  @relation("SupersessionNewer", fields: [supersededByAssessmentId], references: [id])
  supersededThisAssessments Assessment[] @relation("SupersessionNewer")
  supersededThis            Assessment?  @relation("SupersessionOlder", fields: [previousAssessmentId], references: [id])
  newerAssessments          Assessment[] @relation("SupersessionOlder")
  criteriaSet               CriteriaSet? @relation("CriteriaSetAssessments", fields: [criteriaSetId], references: [id])
  hcp                       Hcp          @relation(fields: [hcpId], references: [id])
  specialty                 Specialty?   @relation("AssessmentSpecialty", fields: [specialtyId], references: [id])
  submittedByUser           User         @relation("SubmittedAssessments", fields: [submittedByUserId], references: [id])

  @@index([hcpId, status])
  @@index([submittedByUserId])
  @@index([tenantId, status])
}

model SpecialtyRate {
  id            String      @id @default(uuid())
  specialtyId   String
  criteriaSetId String
  tierLabel     String
  lowRate       Decimal    @db.Decimal(10,2)
  highRate      Decimal    @db.Decimal(10,2)
  tenantId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  criteriaSet   CriteriaSet @relation(fields: [criteriaSetId], references: [id])
  specialty     Specialty   @relation(fields: [specialtyId], references: [id])

  @@unique([specialtyId, criteriaSetId, tierLabel])
  @@index([tenantId])
  @@index([criteriaSetId])
}

model ApplicationSetting {
  id          String   @id @default(uuid())
  key         String
  value       String
  description String?
  tenantId    String
  userId      String?
  updatedAt   DateTime @updatedAt

  @@unique([key, tenantId])
}

model AuditTrail {
  id           String   @id @default(uuid())
  userId       String?
  userName     String?
  entityType   String
  entityId     String
  action       String
  fieldChanged String?
  oldValue     String?
  newValue     String?
  rationale    String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}
